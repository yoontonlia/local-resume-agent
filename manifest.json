{
  "manifest_version": 3,
  "name": "本地简历智能分析助手",
  "version": "1.1.0",
  "description": "基于AI的简历分析工具，支持DeepSeek/OpenAI，所有数据本地处理",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://api.deepseek.com/*",
    "https://api.openai.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "简历分析助手",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "history.html", 
        "batch.html", 
        "compare.html", 
        "optimize.html", 
        "job-match.html",
        "dashboard.html",
        "settings.html",
        "templates.html",
        "lib/pdf.worker.min.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}